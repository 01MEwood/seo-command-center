generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ──
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String   // bcrypt hash
  role      String   @default("viewer") // admin, team, viewer
  active    Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Domains ──
model Domain {
  id        String   @id @default(cuid())
  name      String
  url       String   @unique
  color     String
  createdAt DateTime @default(now())

  keywords     Keyword[]
  articles     Article[]
  gscData      GscDataPoint[]
  pipelineRuns PipelineRun[]
  trackings    TrackedKeyword[]
}

// ── Keywords ──
model Keyword {
  id        String   @id @default(cuid())
  keyword   String
  cluster   String?
  volume    Int      @default(0)
  cpc       Float    @default(0)
  kd        Int      @default(0)
  intent    String?
  trend     String   @default("stable")
  domainId  String
  domain    Domain   @relation(fields: [domainId], references: [id])
  status    String   @default("planned")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article   Article? @relation(fields: [articleId], references: [id])
  articleId String?
  gscData   GscDataPoint[]

  @@unique([keyword, domainId])
  @@index([domainId])
}

// ── Articles ──
model Article {
  id        String   @id @default(cuid())
  number    Int
  title     String
  slug      String
  domainId  String
  domain    Domain   @relation(fields: [domainId], references: [id])
  status    String   @default("planned")
  type      String
  content   String?
  wordCount Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  keywords Keyword[]

  @@index([domainId])
}

// ── GSC Daily Data ──
model GscDataPoint {
  id          String   @id @default(cuid())
  date        DateTime
  query       String
  clicks      Int
  impressions Int
  ctr         Float
  position    Float
  domainId    String
  domain      Domain   @relation(fields: [domainId], references: [id])
  keywordId   String?
  keyword     Keyword? @relation(fields: [keywordId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([date, query, domainId])
  @@index([domainId, date])
  @@index([query])
}

// ═══════════════════════════════════════════════════
// NEW: Ranking Pipeline
// ═══════════════════════════════════════════════════

// A pipeline run = one "Keyword + Region" analysis
model PipelineRun {
  id        String   @id @default(cuid())
  keyword   String
  region    String
  domainId  String
  domain    Domain   @relation(fields: [domainId], references: [id])
  status    String   @default("running") // running, complete, error
  
  // Aggregated data
  searchVolume   Int?
  cpc            Float?
  competition    String?
  ourPosition    Int?       // Where we rank (null = not found)
  ourUrl         String?    // Which URL ranks
  totalResults   Int?
  
  // AI-generated content
  longtails      Json?      // Array of longtail suggestions
  aeoQuestions   Json?      // People Also Ask suggestions
  contentDraft   String?    // Generated article draft
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serpResults SerpResult[]

  @@index([keyword, region])
  @@index([domainId])
}

// Individual SERP position within a pipeline run
model SerpResult {
  id            String   @id @default(cuid())
  pipelineRunId String
  pipelineRun   PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  
  position      Int
  url           String
  domain        String
  title         String
  snippet       String?
  isOurs        Boolean  @default(false)
  
  // Enrichment (optional, fetched separately)
  backlinks     Int?
  da            Int?
  
  createdAt DateTime @default(now())

  @@index([pipelineRunId])
}

// ═══════════════════════════════════════════════════
// NEW: Position Tracking over Time
// ═══════════════════════════════════════════════════

model TrackedKeyword {
  id       String @id @default(cuid())
  keyword  String
  region   String
  domainId String
  domain   Domain @relation(fields: [domainId], references: [id])
  active   Boolean @default(true)
  
  createdAt DateTime @default(now())

  snapshots PositionSnapshot[]

  @@unique([keyword, region, domainId])
  @@index([domainId])
}

model PositionSnapshot {
  id               String   @id @default(cuid())
  trackedKeywordId String
  trackedKeyword   TrackedKeyword @relation(fields: [trackedKeywordId], references: [id], onDelete: Cascade)
  
  position         Int?     // null = not found
  url              String?  // which URL ranked
  searchVolume     Int?
  date             DateTime @default(now())

  @@index([trackedKeywordId, date])
}

// ═══════════════════════════════════════════════════
// NEW v5.4: AI Citation Monitor
// ═══════════════════════════════════════════════════

// A query we monitor across AI engines
model CitationQuery {
  id        String   @id @default(cuid())
  query     String   // "Welche Schreinerei in Stuttgart baut Einbauschränke?"
  keyword   String   // base keyword
  region    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  checks CitationCheck[]

  @@unique([query])
}

// Individual check result per AI engine
model CitationCheck {
  id              String   @id @default(cuid())
  citationQueryId String
  citationQuery   CitationQuery @relation(fields: [citationQueryId], references: [id], onDelete: Cascade)

  engine          String   // chatgpt, perplexity, gemini
  mentioned       Boolean  // was "Schreinerhelden" mentioned?
  mentionType     String?  // direct_citation, recommendation, passing_mention, not_found
  snippet         String?  // the relevant text snippet
  competitorsMentioned String? // JSON array of competitor names mentioned
  fullResponse    String?  // full AI response (for analysis)
  date            DateTime @default(now())

  @@index([citationQueryId, engine, date])
}
