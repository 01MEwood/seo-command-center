# SEO Command Center v5.0 — Environment Variables
# Copy to .env and fill in your values

# Database
DB_NAME=seo_command
DB_USER=seoadmin
DB_PASSWORD=changeme_in_production
DATABASE_URL=postgresql://seoadmin:changeme_in_production@db:5432/seo_command

# Server
NODE_ENV=production
PORT=4000
CORS_ORIGIN=https://seo.meosapp.de
JWT_SECRET=changeme_in_production

# Google OAuth (for GSC, PageSpeed, Indexing API)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# DataForSEO (https://dataforseo.com)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# OpenAI (GPT-4o for content generation)
OPENAI_API_KEY=

# Anthropic (optional, for expert audits)
ANTHROPIC_API_KEY=
